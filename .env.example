# ==========================================================
#  رشاقة — نموذج متغيّرات البيئة (انسخه إلى .env واملأ القيم)
#  ⚠️ لا ترفع ملف .env الحقيقي على git أبداً.
# ==========================================================

# ----- Backend (FastAPI) -----
# سلسلة الاتصال بقاعدة بيانات PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/reshaqa

# مفتاح توقيع JWT — غيّره لقيمة عشوائية طويلة وسرّية في الإنتاج
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200          # 30 يوم

# بيئة التشغيل
APP_ENV=development                          # development | production
APP_DEBUG=true

# أصول مسموح بها للـ CORS (مفصولة بفواصل) — عناوين لوحة الويب/الموبايل
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ----- خدمة تقدير السعرات (قابلة للتبديل) -----
# المزوّد: none | openai | nutrition_api
CALORIE_ESTIMATOR_PROVIDER=none
OPENAI_API_KEY=
NUTRITION_API_KEY=
NUTRITION_API_BASE_URL=

# ----- خدمة الباركود -----
# مثال: Open Food Facts (مجاني، لا يحتاج مفتاح) أو مزوّد آخر
BARCODE_PROVIDER=openfoodfacts
BARCODE_API_KEY=

# ----- خدمة OCR لتصوير جدول التغذية -----
OCR_PROVIDER=none                            # none | tesseract | cloud_vision
OCR_API_KEY=

# ----- هواوي الصحة (Phase 5) -----
HUAWEI_HEALTH_CLIENT_ID=
HUAWEI_HEALTH_CLIENT_SECRET=
HUAWEI_HEALTH_REDIRECT_URI=

# ==========================================================
# ----- Web Dashboard (Next.js) — انسخ هذا القسم إلى web/.env.local -----
# عنوان الـ backend الذي يتصل به المتصفح
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ==========================================================
# ----- Mobile (Flutter) — يُمرَّر عبر --dart-define عند البناء -----
# API_BASE_URL=http://10.0.2.2:8000        # 10.0.2.2 = localhost من محاكي أندرويد
